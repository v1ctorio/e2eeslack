<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>E2EE Slack</title>
    <link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.jade.min.css"
>
    <script src="https://cdn.jsdelivr.net/npm/jsencrypt@latest/bin/jsencrypt.min.js"></script>
</head>
<body>

<main class="container">
    <p>
Hi <%= it.name %>! Your message will be encrypted for <%= it.recipient_names %>
    </p>
    <p>
    </p>
    <form id="formulary">
        <label>
            Passphrase
    <input
      type="password"
      name="passphrase"
      placeholder=""
      id="passphrase-input"
    />
    <small id="passphrase-helper">
        The passphrase you used to encrypt your key
    </small>
        </label>
    <fieldset role="group">
    <input
      id="key-input"
      type="text"
      name="key"
      placeholder=""
      value="fingerprint: <%= it.key_fingerprint %>"
      readonly
    />
  </fieldset>

    <textarea
        id="message-input"
        placeholder="Dear Deer,"
        aria-label="message to encrypt"
        name="message"
    ></textarea>

    <input type="submit" id="submitbutton" value="Encrypt the message" />
</form>

</main>
<style>
    :root {
          --pico-font-size: 1em !important !important;
    }
    body {
                {{!-- background-color: whitesmoke; --}}
    }
</style>

<script type="module">
    <%~ include("./write_message.js.eta") %>
</script>
</body>
</html>